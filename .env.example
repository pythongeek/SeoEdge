# ═══════════════════════════════════════════════════════════════════
# SEOMaster - Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Required) ──────────────────────────────────────────
# Neon PostgreSQL or any Postgres 16+ instance
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── AI: MiniMax M2.7 Direct API (Primary) ────────────────────────
# Get your API key from: https://api.minimax.chat/
MINIMAX_AUTH_TOKEN=sk-cp-your-minimax-token-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Legacy alias (optional - used as fallback)
ANTHROPIC_AUTH_TOKEN=${MINIMAX_AUTH_TOKEN}
ANTHROPIC_BASE_URL=${MINIMAX_BASE_URL}
ANTHROPIC_MODEL=MiniMax-M2.7

# ─── AI: Gemini API (Fallback) ────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Auth: Clerk (Required) ───────────────────────────────────────
# Get these from: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_WEBHOOK_SECRET=whsec_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Redis / BullMQ (Required for background jobs) ────────────────
# Railway Redis: redis://default:password@host:port
# Upstash Redis: rediss://default:password@host:port
REDIS_URL=redis://default:password@host:port

# ─── App URL (Required) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Stripe (Optional - for billing) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_key_here
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── GSC OAuth (Optional - for GSC API integration) ───────────────
GSC_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GSC_CLIENT_SECRET=your-google-oauth-client-secret
GSC_REDIRECT_URI=https://your-app.vercel.app/api/gsc/oauth?action=callback

# GSC Service Account (alternative to OAuth)
GSC_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GSC_SERVICE_ACCOUNT_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# ─── Security (Required) ──────────────────────────────────────────
# Generate a strong 32-character key
ENCRYPTION_KEY=your-32-character-encryption-key!
CRON_SECRET=your-secure-random-string-for-cron

# ─── Worker Configuration ─────────────────────────────────────────
WORKER_CONCURRENCY=2

# ─── Observability (Optional) ─────────────────────────────────────
# Sentry for error tracking: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# PostHog for analytics: https://posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── External API (Optional) ──────────────────────────────────────
# Rate limits per tier
PRO_RATE_LIMIT=1000
BUSINESS_RATE_LIMIT=50000

# ─── Cron Timezone (Optional) ─────────────────────────────────────
CRON_TIMEZONE=UTC
